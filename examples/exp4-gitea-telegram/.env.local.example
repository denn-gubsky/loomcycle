# exp4 secrets + deployment fill-ins — copy to .env.local (run.sh does it on first run).
# Leave a SECRET empty to skip; the *_HOST/_USER/_CHAT_ID lines are non-secret fill-ins.

# Bearer for the loomcycle REST API (/v1/*). Empty = dev open mode. openssl rand -hex 32
LOOMCYCLE_AUTH_TOKEN=

# Model fallback (deepseek-v4-pro). Or use the Anthropic OAuth primary (loomcycle anthropic login).
DEEPSEEK_API_KEY=

# --- Gitea (3rd-party MCP target) ---
LOOMCYCLE_GITEA_TOKEN=                 # SECRET: Gitea access token (write:repository scope)
LOOMCYCLE_GITEA_WEBHOOK_SECRET=        # SECRET: HMAC secret shared with the Gitea repo webhook
LOOMCYCLE_GITEA_HOST=                  # e.g. https://gitea.example.com  (non-secret)
LOOMCYCLE_GITEA_USER=                  # your Gitea username, for git push auth (non-secret)
LOOMCYCLE_GITEA_INSECURE=false         # set true ONLY if the Gitea TLS cert is self-signed/expired

# --- Telegram (notification leg) ---
LOOMCYCLE_TELEGRAM_BOT_TOKEN=          # SECRET: Telegram bot token from @BotFather
LOOMCYCLE_TELEGRAM_CHAT_ID=            # target chat id (non-secret)
