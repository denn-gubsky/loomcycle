# exp2 secrets — copy to .env.local and fill in (run.sh does the copy on first run).
# Leave a value EMPTY to skip that provider/feature.

# Bearer for the loomcycle REST API (/v1/*). Empty = dev open mode (no auth).
# Generate one with: openssl rand -hex 32
LOOMCYCLE_AUTH_TOKEN=

# Fallback provider key (deepseek-v4-pro). Needed unless you use the OAuth primary.
DEEPSEEK_API_KEY=

# Anthropic OAuth primary: no key here — run `loomcycle anthropic login` once
# (token is stored under ~/.config or ~/Library, OUTSIDE this folder).
