# exp9 secrets — copy to .env.local (run.sh does it on first run).
# No external services needed beyond a model provider.

# Bearer for the loomcycle REST API (/v1/*). Empty = dev open mode (no auth).
# For a non-trivial setup: openssl rand -hex 32
LOOMCYCLE_AUTH_TOKEN=

# Model fallback (deepseek-v4-pro). Or use Anthropic OAuth (loomcycle anthropic login).
DEEPSEEK_API_KEY=
